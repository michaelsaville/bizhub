DATABASE_URL=postgresql://user:password@db:5432/dochub

# NextAuth — share with DocHub + TicketHub so SSO works seamlessly.
NEXTAUTH_URL=https://bizhub.pcc2k.com
NEXTAUTH_SECRET=shared-with-dochub-and-tickethub

# Azure AD (Entra) — same tenant as the other apps. Register a new redirect
# URI on the existing app registration: https://bizhub.pcc2k.com/api/auth/callback/azure-ad
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# External data-source credentials (deferred — framework doesn't poll yet).
SAM_GOV_API_KEY=
GRANTS_GOV_API_KEY=

# Anthropic — reuse the TicketHub key or mint a separate bizhub-prod key.
ANTHROPIC_API_KEY=

# Dev-only. In production leave false / unset so secure cookies work.
DISABLE_SECURE_COOKIES=false
